{
  "manifest_version": 3,
  "name": "Web Helper",
  "version": "0.5.0",
  "description": "Personal web workbench: capture page/selection content as markdown, edit it, export or send to an AI chat.",
  "permissions": ["scripting", "storage", "clipboardWrite", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "workbench.html"
  },
  "action": {
    "default_title": "Open Web Helper workbench",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
